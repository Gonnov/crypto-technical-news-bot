# Google Gemini API (free tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Telegram bot — create via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Storage (Railway volume mount path). Use ./data locally.
DATA_DIR=./data

# Schedule
SCHEDULE_TZ=Asia/Bangkok
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# Model
GEMINI_MODEL=gemini-2.5-flash-lite
